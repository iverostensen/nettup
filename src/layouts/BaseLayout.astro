---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import FloatingNav from '../components/layout/FloatingNav.astro';
import ChatWidget from '../components/islands/ChatWidget';
import Footer from '../components/layout/Footer.astro';
import { cities, ACTIVE_TIER } from '@/config/locations';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Nettup lager moderne, raske nettsider for norske bedrifter.',
  image = '/images/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '';

const areaServedCities = cities
  .filter(c => c.tier <= ACTIVE_TIER)
  .map(c => ({ "@type": "City" as const, "name": c.name }));

const areaServed = [
  ...areaServedCities,
  { "@type": "Country" as const, "name": "Norway" },
];

const pageLabels: Record<string, string> = {
  '/': 'Hjem',
  '/tjenester': 'Tjenester',
  '/tjenester/nettside': 'Nettside',
  '/tjenester/nettbutikk': 'Nettbutikk',
  '/tjenester/landingsside': 'Landingsside',
  '/om-oss': 'Om oss',
  '/prosjekter': 'Prosjekter',
  '/prosjekter/igive': 'iGive',
  '/prosjekter/blom-company': 'Blom Company',
  '/kontakt': 'Kontakt',
  '/priskalkulator': 'Prisestimator',
  '/blogg': 'Blogg',
  '/steder': 'Steder',
};

const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbItems: Array<{ position: number; name: string; item?: string }> = [
  { position: 1, name: 'Hjem', item: 'https://nettup.no/' },
  ...pathSegments.map((seg, i) => {
    const fullPath = '/' + pathSegments.slice(0, i + 1).join('/');
    return {
      position: i + 2,
      name: pageLabels[fullPath] ?? seg,
      item: `https://nettup.no${fullPath}`,
    };
  }),
];
// Omit `item` from the last entry per Google specification
if (breadcrumbItems.length > 1) {
  delete breadcrumbItems[breadcrumbItems.length - 1].item;
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map(b => ({
    "@type": "ListItem",
    ...b,
  })),
};
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>html,body{background:#020617;color:#F8FAFC}</style>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#06b6d4" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nb_NO" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nettup",
      "url": "https://nettup.no",
      "logo": "https://nettup.no/images/nettup-logo.svg",
      "description": "Nettup lager moderne, raske nettsider for norske bedrifter.",
      "email": "post@nettup.no",
      "telephone": "+47 413 27 136",
      "areaServed": {
        "@type": "Country",
        "name": "Norway"
      },
      "serviceType": ["Webdesign", "Webutvikling"],
      "knowsLanguage": "nb"
    })} />

    <!-- Structured Data: LocalBusiness (for local search) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://nettup.no/#business",
      "name": "Nettup",
      "description": "Webdesign og webutvikling i Oslo-området. Lanseringstilbud: Nettsider fra 2 500 kr (ordinært 7 000 kr).",
      "url": "https://nettup.no",
      "logo": "https://nettup.no/images/nettup-logo.svg",
      "image": "https://nettup.no/images/og-image.jpg",
      "email": "post@nettup.no",
      "telephone": "+47 413 27 136",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Trollåsveien 4",
        "addressLocality": "Trollåsen",
        "postalCode": "1414",
        "addressRegion": "Viken",
        "addressCountry": "NO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "59.7833",
        "longitude": "10.7833"
      },
      "priceRange": "2500-10000 NOK",
      "paymentAccepted": ["Faktura", "Bankoverføring"],
      "currenciesAccepted": "NOK",
      "areaServed": areaServed,
      "serviceType": ["Webdesign", "Webutvikling", "SEO"],
      "knowsLanguage": "nb",
      "sameAs": [
        "https://www.instagram.com/nettup.no/",
        "https://www.google.com/maps/place/Nettup/@59.8199861,10.7825123,16.66z/data=!4m6!3m5!1s0x464169212ed84087:0x67ffff9b800f58ca!8m2!3d59.819755!4d10.7809133!16s%2Fg%2F11xrfst0hf"
      ]
    })} />

    <!-- Structured Data: Launch Offer -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Offer",
      "name": "Lanseringstilbud - Nettside for Bedrift",
      "description": "Profesjonell nettside til lanseringspris. Kun 10 plasser.",
      "price": "2500",
      "priceCurrency": "NOK",
      "availability": "https://schema.org/LimitedAvailability",
      "seller": {
        "@type": "Organization",
        "name": "Nettup",
        "url": "https://nettup.no"
      }
    })} />

    <!-- Structured Data: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Preload critical assets -->
    <link rel="preload" href="/images/nettup-logo.svg" as="image" type="image/svg+xml" />


    <!-- Privacy-friendly analytics by Plausible -->
    <script is:inline async src="https://plausible.io/js/pa-zcQI8BXyP16x3Uxv8veVj.js"></script>
    <script is:inline>
      /* eslint-disable */
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
      /* eslint-enable */
    </script>

    <!-- Unified Consent Mode v2 + Meta Pixel -->
    <script is:inline define:vars={{ pixelId }}>
      (function() {
        var GTAG_ID = 'AW-17409050017';
        var CONSENT_KEY = 'nettup_ads_consent';

        // --- gtag setup ---
        window.dataLayer = window.dataLayer || [];
        function gtag(){window.dataLayer.push(arguments);}
        window.gtag = gtag;

        gtag('consent', 'default', {
          'ad_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
          'analytics_storage': 'denied',
        });

        // --- fbq setup (Meta Pixel) ---
        if (pixelId) {
          !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){
            n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};
            if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
            n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t,s)}(window,document,'script',
            'https://connect.facebook.net/en_US/fbevents.js');

          fbq('consent', 'revoke');
        }

        // Check stored consent
        var stored = localStorage.getItem(CONSENT_KEY);
        if (stored === 'granted') {
          gtag('consent', 'update', {
            'ad_storage': 'granted',
            'ad_user_data': 'granted',
            'ad_personalization': 'granted',
            'analytics_storage': 'granted',
          });
          if (pixelId && window.fbq) { fbq('consent', 'grant'); }
        }

        // Load gtag.js
        var gs = document.createElement('script');
        gs.src = 'https://www.googletagmanager.com/gtag/js?id=' + GTAG_ID;
        gs.async = true;
        document.head.appendChild(gs);

        // Initialize
        gtag('js', new Date());
        gtag('config', GTAG_ID);

        if (pixelId) {
          fbq('init', pixelId);
          fbq('track', 'PageView');
        }

        window.gtagLoaded = true;

        // Banner visibility
        if (stored === null) {
          document.getElementById('cookie-banner')?.classList.remove('hidden');
        }

        // Accept handler
        document.getElementById('cookie-accept')?.addEventListener('click', function() {
          localStorage.setItem(CONSENT_KEY, 'granted');
          gtag('consent', 'update', {
            'ad_storage': 'granted',
            'ad_user_data': 'granted',
            'ad_personalization': 'granted',
            'analytics_storage': 'granted',
          });
          if (pixelId && window.fbq) { fbq('consent', 'grant'); }
          hideBanner();
        });

        // Decline handler
        document.getElementById('cookie-decline')?.addEventListener('click', function() {
          localStorage.setItem(CONSENT_KEY, 'denied');
          hideBanner();
        });

        function hideBanner() {
          var banner = document.getElementById('cookie-banner');
          if (banner) {
            banner.style.opacity = '0';
            banner.style.transform = 'translateY(100%)';
            banner.style.transition = 'opacity 0.3s, transform 0.3s';
            setTimeout(function() { banner.remove(); }, 300);
          }
        }
      })();
    </script>

    <ClientRouter />

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-surface text-text antialiased">
    <FloatingNav />
    <ChatWidget client:load currentPage={Astro.url.pathname} transition:persist />
    <slot />
    <Footer />

    <!-- Cookie consent banner (site-wide) -->
    <div
      id="cookie-banner"
      class="fixed bottom-0 left-0 right-0 z-50 hidden border-t border-white/10 bg-surface-raised/95 backdrop-blur-md"
      transition:persist
    >
      <div class="container mx-auto flex flex-col items-center justify-between gap-4 px-4 py-4 sm:flex-row">
        <p class="text-sm text-text-muted">
          Vi bruker informasjonskapsler for å måle annonseeffekt. Les mer i vår <a href="/personvern" class="text-brand underline underline-offset-2 transition-colors duration-150 hover:text-brand-light">personvernerklæring</a>.
        </p>
        <div class="flex gap-3">
          <button
            id="cookie-decline"
            class="rounded-full bg-slate-700 px-4 py-2 text-sm font-medium text-text transition-colors hover:bg-slate-600"
          >
            Avslå
          </button>
          <button
            id="cookie-accept"
            class="rounded-full bg-brand px-4 py-2 text-sm font-medium text-surface transition-colors hover:bg-brand-light"
          >
            Godta
          </button>
        </div>
      </div>
    </div>

    <!-- Scroll reveal observer (Level 1 animations) -->
    <script>
      function initScrollObserver() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );
        document.querySelectorAll('.reveal-on-scroll:not(.revealed)').forEach((el) => {
          observer.observe(el);
        });
      }

      // Pre-reveal all scroll-reveal elements in the incoming document before
      // the view-transition snapshot is taken. iOS/WebKit ignores
      // `::view-transition-* { animation: none }` and plays a crossfade anyway —
      // if elements are opacity:0 in the snapshot, the old page bleeds through
      // the transparent holes. Pre-revealing eliminates all transparent holes.
      document.addEventListener('astro:after-preparation', (e) => {
        (e as Event & { newDocument: Document }).newDocument
          .querySelectorAll('.reveal-on-scroll')
          .forEach((el) => el.classList.add('revealed'));
      });

      document.addEventListener('astro:page-load', initScrollObserver);
    </script>
  </body>
</html>
