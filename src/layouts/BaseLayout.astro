---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import FloatingNav from '../components/islands/FloatingNav';
import ChatWidget from '../components/islands/ChatWidget';
import Footer from '../components/layout/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import { cities, ACTIVE_TIER } from '@/config/locations';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Nettup lager moderne, raske nettsider for norske bedrifter.',
  image = '/images/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const areaServedCities = cities
  .filter(c => c.tier <= ACTIVE_TIER)
  .map(c => ({ "@type": "City" as const, "name": c.name }));

const areaServed = [
  ...areaServedCities,
  { "@type": "Country" as const, "name": "Norway" },
];

const pageLabels: Record<string, string> = {
  '/': 'Hjem',
  '/tjenester': 'Tjenester',
  '/tjenester/nettside': 'Nettside',
  '/tjenester/nettbutikk': 'Nettbutikk',
  '/tjenester/landingsside': 'Landingsside',
  '/om-oss': 'Om oss',
  '/prosjekter': 'Prosjekter',
  '/prosjekter/igive': 'iGive',
  '/prosjekter/blom-company': 'Blom Company',
  '/kontakt': 'Kontakt',
  '/priskalkulator': 'Prisestimator',
  '/blogg': 'Blogg',
  '/steder': 'Steder',
};

const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbItems: Array<{ position: number; name: string; item?: string }> = [
  { position: 1, name: 'Hjem', item: 'https://nettup.no/' },
  ...pathSegments.map((seg, i) => {
    const fullPath = '/' + pathSegments.slice(0, i + 1).join('/');
    return {
      position: i + 2,
      name: pageLabels[fullPath] ?? seg,
      item: `https://nettup.no${fullPath}`,
    };
  }),
];
// Omit `item` from the last entry per Google specification
if (breadcrumbItems.length > 1) {
  delete breadcrumbItems[breadcrumbItems.length - 1].item;
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map(b => ({
    "@type": "ListItem",
    ...b,
  })),
};
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>html,body{background:#020617;color:#F8FAFC}</style>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#06b6d4" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nb_NO" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nettup",
      "url": "https://nettup.no",
      "logo": "https://nettup.no/images/nettup-logo.svg",
      "description": "Nettup lager moderne, raske nettsider for norske bedrifter.",
      "email": "post@nettup.no",
      "telephone": "+47 413 27 136",
      "areaServed": {
        "@type": "Country",
        "name": "Norway"
      },
      "serviceType": ["Webdesign", "Webutvikling"],
      "knowsLanguage": "nb"
    })} />

    <!-- Structured Data: LocalBusiness (for local search) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://nettup.no/#business",
      "name": "Nettup",
      "description": "Webdesign og webutvikling i Oslo-området. Lanseringstilbud: Nettsider fra 2 500 kr (ordinært 7 000 kr).",
      "url": "https://nettup.no",
      "logo": "https://nettup.no/images/nettup-logo.svg",
      "image": "https://nettup.no/images/og-image.jpg",
      "email": "post@nettup.no",
      "telephone": "+47 413 27 136",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Trollåsveien 4",
        "addressLocality": "Trollåsen",
        "postalCode": "1414",
        "addressRegion": "Viken",
        "addressCountry": "NO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "59.7833",
        "longitude": "10.7833"
      },
      "priceRange": "2500-10000 NOK",
      "paymentAccepted": ["Faktura", "Bankoverføring"],
      "currenciesAccepted": "NOK",
      "areaServed": areaServed,
      "serviceType": ["Webdesign", "Webutvikling", "SEO"],
      "knowsLanguage": "nb",
      "sameAs": [
        "https://www.instagram.com/nettup.no/",
        "https://www.google.com/maps/place/Nettup/@59.8199861,10.7825123,16.66z/data=!4m6!3m5!1s0x464169212ed84087:0x67ffff9b800f58ca!8m2!3d59.819755!4d10.7809133!16s%2Fg%2F11xrfst0hf"
      ]
    })} />

    <!-- Structured Data: Launch Offer -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Offer",
      "name": "Lanseringstilbud - Nettside for Bedrift",
      "description": "Profesjonell nettside til lanseringspris. Kun 10 plasser.",
      "price": "2500",
      "priceCurrency": "NOK",
      "availability": "https://schema.org/LimitedAvailability",
      "seller": {
        "@type": "Organization",
        "name": "Nettup",
        "url": "https://nettup.no"
      }
    })} />

    <!-- Structured Data: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Preload critical assets -->
    <link rel="preload" href="/images/nettup-logo.svg" as="image" type="image/svg+xml" />


    <!-- Analytics -->
    <Analytics />
    <!-- Privacy-friendly analytics by Plausible -->
    <script is:inline async src="https://plausible.io/js/pa-zcQI8BXyP16x3Uxv8veVj.js"></script>
    <script is:inline>
      /* eslint-disable */
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
      /* eslint-enable */
    </script>
    <ClientRouter />

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-surface text-text antialiased">
    <FloatingNav client:only="react" />
    <ChatWidget client:load currentPage={Astro.url.pathname} transition:persist />
    <slot />
    <Footer />

    <!-- Hide body during DOM swap + hydration to prevent raw SSR HTML flash -->
    <script>
      document.addEventListener('astro:before-swap', () => {
        document.documentElement.dataset.loading = '';
      });
      document.addEventListener('astro:page-load', () => {
        delete document.documentElement.dataset.loading;
      });
    </script>

    <!-- Scroll reveal observer (Level 1 animations) -->
    <script>
      function initScrollObserver() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );
        // Only observe elements not yet revealed (prevents re-animating on same page)
        document.querySelectorAll('.reveal-on-scroll:not(.revealed)').forEach((el) => {
          observer.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initScrollObserver);
    </script>
  </body>
</html>
