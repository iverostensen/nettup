---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

interface Props {
  relatedSlugs?: string[];
  currentSlug: string;
}

const { relatedSlugs = [], currentSlug } = Astro.props;

const allArticles = await getCollection('blogg');
const related: CollectionEntry<'blogg'>[] = relatedSlugs
  .map((slug) => allArticles.find((a) => a.slug === slug))
  .filter((a): a is NonNullable<typeof a> => a !== undefined)
  .filter((a) => a.slug !== currentSlug)
  .slice(0, 3);
---

{
  related.length > 0 && (
    <section>
      <h2 class="mb-6 text-xl font-semibold text-text">Les også</h2>
      <div
        class:list={[
          'grid gap-6',
          related.length === 1 && 'grid-cols-1',
          related.length === 2 && 'grid-cols-1 md:grid-cols-2',
          related.length >= 3 && 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
        ]}
      >
        {related.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )
}
