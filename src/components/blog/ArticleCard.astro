---
import Card from '@/components/ui/Card.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'blogg'>;
}

const { article } = Astro.props;

const formattedDate = article.data.date.toLocaleDateString('nb-NO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Card as="a" href={`/blogg/${article.slug}`} hover={true}>
  <div class="flex flex-col gap-3">
    <span class="text-xs font-medium uppercase tracking-wide text-brand">
      {article.data.category}
    </span>
    <h2 class="text-lg font-semibold leading-snug text-text">
      {article.data.title}
    </h2>
    <p class="line-clamp-2 text-sm text-text-muted">{article.data.description}</p>
    <p class="text-sm text-text-muted">
      {formattedDate} · {article.data.readTime} min lesing
    </p>
  </div>
</Card>
