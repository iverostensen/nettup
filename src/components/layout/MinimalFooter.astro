---
/**
 * MinimalFooter - Simplified footer for landing pages
 *
 * Contains only essential contact info, no navigation links.
 * Reduces exit points for better conversion.
 */
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-surface">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col items-center justify-between gap-6 text-center md:flex-row md:text-left">
      <!-- Logo and contact -->
      <div class="flex flex-col items-center gap-4 md:flex-row md:gap-6">
        <a href="#" class="transition-opacity hover:opacity-80">
          <img
            src="/images/nettup-logo.svg"
            alt="Nettup"
            width="68"
            height="28"
            class="h-7 w-auto"
          />
        </a>
        <div class="flex items-center gap-4 text-sm text-text-muted">
          <a
            href="mailto:post@nettup.no"
            class="flex items-center gap-2 transition-colors hover:text-brand"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              />
            </svg>
            post@nettup.no
          </a>
          <span class="text-text-muted/50">|</span>
          <span>Vi svarer innen 24 timer</span>
        </div>
      </div>

      <!-- Copyright and privacy -->
      <div class="flex items-center gap-3 text-xs text-text-muted">
        <span>&copy; {currentYear} Nettup</span>
        <span class="text-text-muted/50">|</span>
        <a href="/personvern" class="transition-colors hover:text-brand">
          Personvern
        </a>
      </div>
    </div>
  </div>
</footer>
