---
interface Props {
  as?: 'div' | 'article' | 'a';
  href?: string;
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg' | 'none';
  class?: string;
  [key: string]: any;
}

const {
  as: Tag = 'div',
  href,
  hover = false,
  padding = 'md',
  class: className,
  ...rest
} = Astro.props;

const paddingSizes: Record<NonNullable<Props['padding']>, string> = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const classes = [
  'rounded-md border border-white/10 bg-surface-raised',
  paddingSizes[padding],
  hover && 'transition-all duration-normal hover:border-brand/30 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand/5',
  className,
].filter(Boolean).join(' ');

const Element = href ? 'a' : Tag;
---

<Element href={href} class={classes} {...rest}>
  <slot />
</Element>
