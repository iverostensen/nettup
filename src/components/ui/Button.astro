---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  [key: string]: any;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className,
  ...rest
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-semibold transition-colors rounded-full';

const variants = {
  primary: 'bg-brand text-surface hover:bg-brand-light',
  secondary: 'border border-white/20 text-text hover:border-white/40 hover:bg-white/5',
  ghost: 'text-brand hover:text-brand-light',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3',
  lg: 'px-8 py-4 text-lg',
};

const classes = [baseClasses, variants[variant], sizes[size], className].filter(Boolean).join(' ');
const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes} {...rest}>
  <slot />
</Tag>
