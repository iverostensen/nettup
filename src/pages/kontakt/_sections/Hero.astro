---
import Section from '@/components/ui/Section.astro';
---

<Section padding="hero">
  <div class="mx-auto max-w-3xl text-center">
    <h1 class="reveal-on-scroll text-4xl font-bold md:text-5xl lg:text-6xl">
      La oss snakke om din nettside
    </h1>
    <p class="reveal-on-scroll reveal-delay-1 mt-6 text-lg text-text-muted md:text-xl">
      Har du spørsmål, eller vil du vite mer om hva vi kan gjøre for deg? Send oss en melding, så
      svarer vi innen 24 timer.
    </p>
  </div>
</Section>
