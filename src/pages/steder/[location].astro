---
import { cities, ACTIVE_TIER, type City } from '@/config/locations';
import { services } from '@/config/services';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Testimonials from '@/pages/_home/Testimonials.astro';

export function getStaticPaths() {
  return cities
    .filter((city) => city.tier <= ACTIVE_TIER)
    .map((city) => ({
      params: { location: city.slug },
      props: { city },
    }));
}

interface Props {
  city: City;
}

const { city } = Astro.props;

const allServices = ['nettside', 'nettbutikk', 'landingsside']
  .map((slug) => services.find((s) => s.slug === slug))
  .filter(Boolean);

const nettside = services.find((s) => s.slug === 'nettside')!;

const faqSchema =
  city.faq && city.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: city.faq.map((item: { question: string; answer: string }) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null;

const steps = [
  {
    step: '1',
    title: 'Samtale',
    desc: 'Vi tar en uforpliktende prat om hva du trenger. Ingen salgspress — bare ærlige råd.',
  },
  {
    step: '2',
    title: 'Vi bygger',
    desc: 'Du godkjenner design og vi bygger nettsiden. Du følger prosessen underveis.',
  },
  {
    step: '3',
    title: 'Lansering',
    desc: 'Nettsiden går live. Vi sørger for at alt fungerer og at du er klar til å ta imot kunder.',
  },
];
---

<BaseLayout title={city.metaTitle} description={city.metaDescription}>
  <Fragment slot="head">
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Service',
        '@id': `https://nettup.no/steder/${city.slug}#service`,
        name: `Nettside for bedrift i ${city.name}`,
        description: `Profesjonelle nettsider for bedrifter i ${city.name}. Moderne design, rask levering og god synlighet i Google. Vi jobber digitalt og leverer raskt.`,
        provider: { '@id': 'https://nettup.no/#business' },
        areaServed: [
          { '@type': 'City', name: city.name },
          ...cities
            .filter((c) => city.nearbyAreas.includes(c.slug))
            .map((c) => ({ '@type': 'City', name: c.name })),
        ],
        url: `https://nettup.no/steder/${city.slug}`,
        potentialAction: {
          '@type': 'ContactAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: 'https://nettup.no/kontakt',
          },
        },
      })}
    />
    {faqSchema && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(faqSchema)}
      />
    )}
  </Fragment>
  <main>
    <Section class="pt-32 md:pt-40">
      <Breadcrumbs
        items={[
          { label: 'Hjem', href: '/' },
          { label: 'Steder', href: '/steder' },
          { label: city.name },
        ]}
      />
      <div class="mt-6 max-w-3xl">
        <h1 class="reveal-on-scroll reveal-stagger-1 text-4xl font-bold md:text-5xl">
          Nettside for bedrift i {city.name}
        </h1>
        <p class="reveal-on-scroll reveal-stagger-2 mt-4 text-lg text-text-muted">
          {city.intro}
        </p>
        <div class="reveal-on-scroll reveal-stagger-3 mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <Button href={`/kontakt?sted=${city.slug}`} size="lg">Få et gratis tilbud</Button>
          <span class="text-sm text-text-muted">
            {nettside.priceRange} · Klar på 2–4 uker
          </span>
        </div>
      </div>
    </Section>

    <Section background="raised">
      <SectionHeader
        title="Tjenester vi tilbyr"
        subtitle={`Vi hjelper bedrifter i ${city.name} med alt fra enkle nettsider til nettbutikker`}
      />
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          allServices.map((service) => (
            <Card as="a" href={`/tjenester/${service!.slug}`} hover padding="lg" class="flex flex-col">
              <h3 class="mb-1 font-semibold text-text">{service!.name}</h3>
              <p class="mb-3 text-sm text-brand">{service!.tagline}</p>
              <p class="mt-auto text-sm font-semibold text-text-muted">{service!.priceRange}</p>
            </Card>
          ))
        }
      </div>
    </Section>

    <Section>
      <SectionHeader title="Slik jobber vi" subtitle="Enkelt, digitalt og uten unødvendig venting" />
      <div class="mt-10 grid gap-8 md:grid-cols-3">
        {
          steps.map((item) => (
            <div class="reveal-on-scroll flex flex-col items-start gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand/20 text-xl font-bold text-brand">
                {item.step}
              </div>
              <h3 class="text-lg font-semibold">{item.title}</h3>
              <p class="text-text-muted">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </Section>

    <Testimonials />

    <Section background="raised">
      <SectionHeader
        title="Vanlige spørsmål"
        subtitle={`Spørsmål og svar for bedrifter i ${city.name}`}
      />
      <div class="mt-10 space-y-4">
        {
          city.faq.map((item) => (
            <details class="group rounded-lg border border-white/10 bg-surface p-6">
              <summary class="cursor-pointer list-none font-semibold text-text [&::-webkit-details-marker]:hidden">
                {item.question}
              </summary>
              <p class="mt-3 text-text-muted">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </Section>

    <Section>
      <SectionHeader
        title="Områder vi dekker i nærheten"
        subtitle={`Vi hjelper bedrifter i ${city.name} og nærliggende kommuner`}
      />
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {
          city.nearbyAreas.map((area) => {
            const nearbyCity = cities.find((c) => c.slug === area);
            const label = nearbyCity?.name ?? area;
            return (
              <a
                href={`/steder/${area}`}
                class="rounded-full border border-brand/40 bg-brand/10 px-5 py-2 text-sm font-medium text-brand transition hover:border-brand hover:bg-brand/20"
              >
                {label}
              </a>
            );
          })
        }
      </div>
    </Section>

    <Section background="raised">
      <div class="reveal-on-scroll mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold md:text-4xl">Klar for en ny nettside?</h2>
        <p class="mt-4 text-lg text-text-muted">
          Ta kontakt for en uforpliktende prat om hva vi kan gjøre for din bedrift i {city.name}.
        </p>
        <div class="mt-8">
          <a
            href="/kontakt"
            id="city-cta"
            data-city={city.slug}
            class="inline-flex items-center justify-center rounded-md bg-brand px-6 py-3 text-base font-semibold text-surface transition-colors hover:bg-brand-light focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 focus:ring-offset-surface"
          >
            Ta kontakt
          </a>
        </div>
      </div>
    </Section>
  </main>
</BaseLayout>

<script is:inline>
  (function () {
    var btn = document.getElementById('city-cta');
    if (btn) {
      btn.addEventListener('click', function () {
        var city = btn.getAttribute('data-city');
        if (city && window.plausible) {
          window.plausible('City CTA Clicked', { props: { city: city } });
        }
      });
    }
  })();
</script>
