---
import { Image } from 'astro:assets';
import Section from '@/components/ui/Section.astro';
import Card from '@/components/ui/Card.astro';
import { projects } from '@/config/projects';
import { testimonials } from '@/config/testimonials';

const iGiveTestimonial = testimonials.find((t) => t.company === 'iGive');

const caseStudyProject = projects.find((p) => p.caseStudySection === true);
const additionalProjects = projects.filter((p) => p.caseStudySection !== true);
---

<Section background="raised">
  <div class="space-y-12">
    {
      caseStudyProject && (
        <>
          {/* Project Header */}
          <div class="reveal-on-scroll">
            <div class="flex flex-wrap items-center gap-3 text-sm">
              <span class="rounded-full bg-brand/10 px-3 py-1 text-brand">
                {caseStudyProject.category}
              </span>
              <span class="text-text-muted">{caseStudyProject.type}</span>
            </div>
            <h2 class="mt-4 text-3xl font-bold md:text-4xl">{caseStudyProject.name}</h2>
            <p class="mt-2 max-w-2xl text-lg text-text-muted">{caseStudyProject.description}</p>
            {caseStudyProject.url && (
              <a
                href={caseStudyProject.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 font-medium text-brand transition-colors hover:text-brand-light"
              >
                Besøk siden
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="h-4 w-4"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                  />
                </svg>
              </a>
            )}
          </div>

          {/* Hero Screenshot */}
          <div class="reveal-on-scroll delay-1 overflow-hidden rounded-xl border border-white/10">
            <Image
              src={caseStudyProject.image}
              alt={caseStudyProject.imageAlt}
              width={1600}
              quality={85}
              class="w-full"
              loading="eager"
            />
          </div>

          {/* Challenge / Solution Grid */}
          {caseStudyProject.challenge && caseStudyProject.solution && (
            <div class="grid gap-8 md:grid-cols-2">
              <Card padding="lg" class="reveal-on-scroll delay-2">
                <h3 class="text-xl font-semibold">Utfordringen</h3>
                <p class="mt-3 text-text-muted">{caseStudyProject.challenge}</p>
              </Card>
              <Card padding="lg" class="reveal-on-scroll delay-3">
                <h3 class="text-xl font-semibold">Løsningen</h3>
                <p class="mt-3 text-text-muted">{caseStudyProject.solution}</p>
              </Card>
            </div>
          )}

          {/* Features Delivered */}
          {caseStudyProject.features && caseStudyProject.features.length > 0 && (
            <div class="reveal-on-scroll delay-4">
              <h3 class="text-xl font-semibold">Hva vi leverte</h3>
              <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {caseStudyProject.features.map((feature) => (
                  <div class="flex items-center gap-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                      class="h-5 w-5 flex-shrink-0 text-brand"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="m4.5 12.75 6 6 9-13.5"
                      />
                    </svg>
                    <span class="text-text-muted">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Client Quote */}
          {iGiveTestimonial && (
            <div class="reveal-on-scroll border-l-2 border-brand/40 pl-6">
              <div class="text-3xl font-bold leading-none text-brand/30" aria-hidden="true">&ldquo;</div>
              <blockquote class="mt-2">
                <p class="text-lg leading-relaxed text-text">{iGiveTestimonial.quote}</p>
                {iGiveTestimonial.result && (
                  <p class="mt-3 font-semibold text-brand">{iGiveTestimonial.result}</p>
                )}
              </blockquote>
              <footer class="mt-4 flex items-center gap-3">
                {iGiveTestimonial.photoUrl ? (
                  <img
                    src={iGiveTestimonial.photoUrl}
                    alt={iGiveTestimonial.name}
                    class="h-10 w-10 rounded-full object-cover flex-shrink-0"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="h-10 w-10 flex-shrink-0 rounded-full bg-brand/20 flex items-center justify-center"
                    aria-hidden="true"
                  >
                    <span class="text-sm font-semibold text-brand">{iGiveTestimonial.name.charAt(0)}</span>
                  </div>
                )}
                <div>
                  <cite class="not-italic font-semibold text-text">{iGiveTestimonial.name}</cite>
                  <p class="text-sm text-text-muted">{iGiveTestimonial.title}, {iGiveTestimonial.company}</p>
                </div>
              </footer>
            </div>
          )}
        </>
      )
    }

    {/* Additional project cards (future projects) */}
    {
      additionalProjects.length > 0 && (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {additionalProjects.map((project) => (
            <Card padding="lg">
              <div class="flex flex-wrap items-center gap-3 text-sm">
                <span class="rounded-full bg-brand/10 px-3 py-1 text-brand">
                  {project.category}
                </span>
                {project.comingSoon && (
                  <span class="rounded-full bg-white/10 px-3 py-1 text-text-muted text-xs">
                    Kommer snart
                  </span>
                )}
              </div>
              <h3 class="mt-4 text-xl font-semibold">{project.name}</h3>
              <p class="mt-2 text-text-muted">{project.description}</p>
              {project.url && !project.comingSoon && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-brand transition-colors hover:text-brand-light"
                >
                  Besøk siden
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                    />
                  </svg>
                </a>
              )}
            </Card>
          ))}
        </div>
      )
    }
  </div>
</Section>
