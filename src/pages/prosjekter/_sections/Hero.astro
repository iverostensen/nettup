---
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    preload="none"
    class="absolute inset-0 h-full w-full object-cover"
    aria-hidden="true"
  >
    <source src="/videos/neural-network-dark-compressed.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-surface/72" aria-hidden="true"></div>

  <!-- Bottom gradient: blends into ProjectShowcase section -->
  <div
    class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-surface to-transparent"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-3xl px-4 text-center">
    <h1 class="animate-fade-up text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
      Vårt arbeid
    </h1>
    <p
      class="animate-fade-up mt-6 text-lg text-text-muted md:text-xl"
      style="animation-delay: 100ms"
    >
      Vi bygger nettsider som er raske, moderne og enkle å bruke.
      Her er et eksempel på hva vi kan lage for deg.
    </p>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    video {
      display: none;
    }
  }
</style>
