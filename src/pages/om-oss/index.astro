import Values from './_sections/Values.astro';
import Approach from './_sections/Approach.astro';
import OmOssCTA from './_sections/OmOssCTA.astro';
---

<BaseLayout
  title="Om Nettup | Webbyrå i Oslo-området | Moderne nettsider"
