---
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    preload="none"
    class="absolute inset-0 h-full w-full object-cover"
    aria-hidden="true"
  >
    <source src="/videos/code-flowing-down-compressed.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-surface/72" aria-hidden="true"></div>

  <!-- Bottom gradient: blends into Values section -->
  <div
    class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-surface to-transparent"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-3xl px-4 text-center">
    <h1 class="font-display animate-fade-up text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
      Vi så et problem.
    </h1>
    <p
      class="animate-fade-up mt-6 text-lg text-text-muted md:text-xl"
      style="animation-delay: 100ms"
    >
      Norske småbedrifter fortjener gode nettsider. Men altfor mange sitter fast med dyre byråer,
      uendelige ventetider og løsninger som er mer kompliserte enn de trenger å være.
    </p>
    <p
      class="animate-fade-up mt-4 text-lg text-text-muted md:text-xl"
      style="animation-delay: 200ms"
    >
      Derfor startet vi <span class="text-brand font-semibold">Nettup</span>.
      For å gjøre det enklere.
    </p>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    video {
      display: none;
    }
  }
</style>
