---
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Card from '@/components/ui/Card.astro';

const values = [
  {
    title: 'Enkelhet',
    description: 'Ingen unødvendig kompleksitet. Du får det du trenger - ikke mer, ikke mindre.',
    icon: 'check',
  },
  {
    title: 'Ærlighet',
    description: 'Tydelige priser fra dag én. Ingen skjulte kostnader eller overraskelser.',
    icon: 'shield',
  },
  {
    title: 'Fart',
    description: 'Rask levering, raske svar. Du venter ikke i uker på en e-post fra oss.',
    icon: 'bolt',
  },
];

const icons = {
  check: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  shield: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
  bolt: 'm3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z',
};
---

<Section background="raised">
  <SectionHeader
    title="Det vi tror på"
    subtitle="Tre prinsipper som styrer alt vi gjør."
  />
  <div class="grid gap-8 md:grid-cols-3">
    {values.map((value, index) => (
      <Card
        as="article"
        padding="lg"
        class={`reveal-on-scroll reveal-delay-${index + 1}`}
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand/10">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="h-6 w-6 text-brand"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={icons[value.icon as keyof typeof icons]} />
          </svg>
        </div>
        <h3 class="text-xl font-semibold">{value.title}</h3>
        <p class="mt-2 text-text-muted">{value.description}</p>
      </Card>
    ))}
  </div>
</Section>
