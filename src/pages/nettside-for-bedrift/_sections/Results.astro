---
/**
 * Results - Social proof through metrics
 *
 * Shows Lighthouse performance scores from delivered projects.
 * Builds credibility without requiring testimonial content.
 */

const metrics = [
  {
    value: '95',
    label: 'Ytelse',
    description: 'Lighthouse score',
  },
  {
    value: '<1s',
    label: 'Lastetid',
    description: 'Fullt lastet',
  },
  {
    value: '100',
    label: 'SEO',
    description: 'Søkemotor-score',
  },
];
---

<section class="py-12 md:py-16">
  <div class="container mx-auto px-4">
    <div class="reveal-on-scroll mx-auto max-w-3xl text-center">
      <p class="text-sm font-medium uppercase tracking-wider text-brand">
        Dokumenterte resultater
      </p>
      <h2 class="mt-2 text-2xl font-bold md:text-3xl">
        Nettsider som faktisk leverer
      </h2>
      <p class="mt-3 text-text-muted">
        Tall fra våre leveranser, målt med Google Lighthouse.
      </p>
    </div>

    <!-- Metrics -->
    <div class="reveal-on-scroll reveal-delay-1 mx-auto mt-10 grid max-w-2xl grid-cols-3 gap-4 md:gap-8">
      {metrics.map((metric) => (
        <div class="text-center">
          <div class="text-3xl font-bold text-brand md:text-4xl lg:text-5xl">
            {metric.value}
          </div>
          <div class="mt-1 text-sm font-medium md:text-base">{metric.label}</div>
          <div class="text-xs text-text-muted md:text-sm">{metric.description}</div>
        </div>
      ))}
    </div>

    <!-- Trust line -->
    <p class="reveal-on-scroll reveal-delay-2 mt-8 text-center text-sm text-text-muted">
      Basert på <a href="/prosjekter" class="text-brand hover:text-brand-light">tidligere prosjekter</a>
    </p>
  </div>
</section>
