---
/**
 * Landing Page Hero - Keyword-matched headline for Google Ads
 *
 * Key differences from homepage hero:
 * - H1 matches ad keyword "nettside for bedrift"
 * - Price prominently displayed
 * - Urgency language
 * - Trust badges above the fold
 * - Single focused CTA
 * - Animated code-to-website transformation
 */
import LandingHeroAnimation from '@/components/islands/LandingHeroAnimation';
---

<section class="relative overflow-hidden py-12 md:py-20">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute left-1/4 top-0 h-96 w-96 rounded-full bg-brand/10 blur-3xl"
    >
    </div>
    <div
      class="absolute right-1/4 bottom-0 h-64 w-64 rounded-full bg-brand/5 blur-3xl"
    >
    </div>
  </div>

  <div class="container mx-auto px-4">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Text content -->
      <div class="text-center lg:text-left">
      <!-- Main headline - matches Google Ads keyword -->
      <h1 class="reveal-on-scroll text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
        Profesjonell nettside
        <span class="text-brand">for din bedrift</span>
      </h1>

      <!-- Value proposition with price -->
      <p class="reveal-on-scroll reveal-delay-1 mt-6 text-xl text-text-muted md:text-2xl">
        Fra <span class="font-semibold text-text">7 000 kr</span> – Klar på 1-3 uker
      </p>

      <!-- Trust badges -->
      <div class="reveal-on-scroll reveal-delay-2 mt-8 flex flex-wrap items-center justify-center gap-4 md:gap-6 lg:justify-start">
        <div class="flex items-center gap-2 rounded-full bg-surface-raised px-4 py-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-5 w-5 text-brand"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
            />
          </svg>
          <span class="text-sm font-medium">24t responstid</span>
        </div>

        <div class="flex items-center gap-2 rounded-full bg-surface-raised px-4 py-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-5 w-5 text-brand"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m4.5 12.75 6 6 9-13.5"
            />
          </svg>
          <span class="text-sm font-medium">Gratis tilbud</span>
        </div>

        <div class="flex items-center gap-2 rounded-full bg-surface-raised px-4 py-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-5 w-5 text-brand"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
            />
          </svg>
          <span class="text-sm font-medium">Ingen binding</span>
        </div>
      </div>

      <!-- Primary CTA -->
      <div class="reveal-on-scroll reveal-delay-3 mt-10">
        <a
          href="#kontakt"
          class="inline-flex items-center gap-2 rounded-full bg-brand px-8 py-4 text-lg font-semibold text-surface transition-all hover:scale-105 hover:bg-brand-light hover:shadow-lg hover:shadow-brand/25 active:scale-100"
        >
          Få tilbud på din nettside
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-5 w-5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"
            />
          </svg>
        </a>
      </div>

      </div>

      <!-- Animation -->
      <div class="reveal-on-scroll reveal-delay-2 hidden lg:block">
        <LandingHeroAnimation client:load />
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="reveal-on-scroll reveal-delay-4 mt-10 text-center">
      <p class="text-sm text-text-muted">Se våre pakker</p>
      <div class="mt-2 flex justify-center">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="h-6 w-6 animate-bounce text-text-muted"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m19.5 8.25-7.5 7.5-7.5-7.5"
          />
        </svg>
      </div>
    </div>
  </div>
</section>
