---
/**
 * FAQ - Common questions with JSON-LD schema
 *
 * Improves:
 * - Google Ads Quality Score (relevance)
 * - Potential rich snippets in search
 * - Addresses objections before form submission
 */

const faqs = [
  {
    question: 'Hva får jeg for 399 kr/mnd?',
    answer:
      'Du får en komplett, profesjonell nettside med inntil 5 sider, responsivt design, kontaktskjema, grunnleggende SEO, SSL-sertifikat og hosting. I tillegg er support og vedlikehold inkludert – vi tar oss av alt det tekniske.',
  },
  {
    question: 'Hva skjer om jeg sier opp?',
    answer:
      'Du slipper å tenke på hosting, oppdateringer og sikkerhet så lenge du er kunde – vi tar oss av alt. Hvis du sier opp, tas nettsiden ned. Det er ingen bindingstid, så du kan avslutte når som helst.',
  },
  {
    question: 'Hva om jeg ikke er fornøyd?',
    answer:
      'Ikke fornøyd etter første måned? Da betaler du ingenting. Med 0 kr i oppstart risikerer du kun 399 kr. Vi jobber tett med deg til du er helt fornøyd med resultatet.',
  },
  {
    question: 'Hvor lang tid tar det å lage nettsiden?',
    answer:
      'De fleste nettsider er klare på 1-3 uker. Vi starter med en kort samtale for å forstå behovene dine, og går i gang med en gang.',
  },
  {
    question: 'Låser jeg meg for å betale for alltid?',
    answer:
      'Nei. Det er ingen bindingstid – du kan si opp når som helst. Tenk på det som en Netflix-abonnement for nettsiden din: så lenge du er kunde, tar vi oss av alt. Slutter du, stopper tjenesten.',
  },
  {
    question: 'Hva om jeg trenger mer enn 5 sider?',
    answer:
      'Abonnementet dekker inntil 5 sider. Trenger du en større eller mer avansert løsning, tilbyr vi skreddersydde nettsider og nettbutikker. Ta kontakt så finner vi den beste løsningen for deg.',
  },
];

// Generate FAQ schema for Google rich snippets
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="py-12 md:py-16">
  <div class="container mx-auto px-4">
    <div class="reveal-on-scroll mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold md:text-3xl">Vanlige spørsmål</h2>
      <p class="mt-3 text-text-muted">
        Svar på det du kanskje lurer på
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-2xl space-y-6">
      {faqs.map((faq, index) => (
        <div class={`reveal-on-scroll delay-${(index % 3) + 1}`}>
          <h3 class="text-lg font-semibold">{faq.question}</h3>
          <p class="mt-2 text-text-muted">{faq.answer}</p>
        </div>
      ))}
    </div>

    <!-- CTA after FAQ -->
    <div class="reveal-on-scroll mt-10 text-center">
      <p class="text-text-muted">
        Har du andre spørsmål?
        <a href="#kontakt" class="text-brand hover:text-brand-light">
          Ta kontakt – vi svarer innen 24 timer
        </a>
      </p>
    </div>
  </div>
</section>

<!-- FAQ Schema for rich snippets -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
