---
/**
 * FAQ - Common questions with JSON-LD schema
 *
 * Improves:
 * - Google Ads Quality Score (relevance)
 * - Potential rich snippets in search
 * - Addresses objections before form submission
 */

const faqs = [
  {
    question: 'Hva koster en bedriftsnettside?',
    answer:
      'Våre pakker starter fra 7 000 kr for en enkel nettside med inntil 5 sider. Standard-pakken koster 15 000 kr og inkluderer flere funksjoner. For skreddersydde løsninger starter prisen fra 25 000 kr.',
  },
  {
    question: 'Hvor lang tid tar det å lage en nettside?',
    answer:
      'De fleste nettsider er klare på 1-3 uker, avhengig av omfang og kompleksitet. Vi gir deg en konkret tidsramme etter første samtale.',
  },
  {
    question: 'Hva hvis jeg ikke er fornøyd med resultatet?',
    answer:
      'Vi tilbyr full tilfredsgaranti. Hvis du ikke er fornøyd med nettsiden etter ferdigstillelse, gjør vi ubegrensede justeringer til du er helt fornøyd. Hvis vi fortsatt ikke møter forventningene dine, refunderer vi hele beløpet.',
  },
  {
    question: 'Eier jeg nettsiden selv?',
    answer:
      'Ja, du eier nettsiden din. Det er ingen binding, og du kan når som helst flytte nettsiden til en annen leverandør om du ønsker det.',
  },
  {
    question: 'Hva er inkludert i månedsprisen?',
    answer:
      'Månedsprisen dekker hosting, SSL-sertifikat, teknisk support og mindre oppdateringer. Du trenger ikke tenke på drift – vi tar oss av det.',
  },
  {
    question: 'Må jeg betale alt på forhånd?',
    answer:
      'Nei, vi fakturerer 50% ved oppstart og 50% ved levering. Slik har du trygghet underveis i prosjektet.',
  },
];

// Generate FAQ schema for Google rich snippets
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="py-12 md:py-16">
  <div class="container mx-auto px-4">
    <div class="reveal-on-scroll mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold md:text-3xl">Vanlige spørsmål</h2>
      <p class="mt-3 text-text-muted">
        Svar på det du kanskje lurer på
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-2xl space-y-6">
      {faqs.map((faq, index) => (
        <div class={`reveal-on-scroll reveal-delay-${(index % 3) + 1}`}>
          <h3 class="text-lg font-semibold">{faq.question}</h3>
          <p class="mt-2 text-text-muted">{faq.answer}</p>
        </div>
      ))}
    </div>

    <!-- CTA after FAQ -->
    <div class="reveal-on-scroll mt-10 text-center">
      <p class="text-text-muted">
        Har du andre spørsmål?
        <a href="#kontakt" class="text-brand hover:text-brand-light">
          Ta kontakt – vi svarer innen 24 timer
        </a>
      </p>
    </div>
  </div>
</section>

<!-- FAQ Schema for rich snippets -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
