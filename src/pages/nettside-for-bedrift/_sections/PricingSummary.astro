---
/**
 * PricingSummary - Simplified pricing for landing page
 *
 * Shows 3 tiers with essential info only.
 * CTAs link to the form section below (not to /kontakt/).
 */
import ScarcityCounter from '@/components/ui/ScarcityCounter.astro';
import PriceDisplay from '@/components/ui/PriceDisplay.astro';

const pakker = [
  {
    name: 'Enkel',
    description: 'Profesjonell tilstedeværelse på nett',
    originalPrice: '7 000',
    launchPrice: '2 500',
    savings: '4 500',
    discountPercent: '64',
    monthly: '350',
    features: ['Inntil 5 sider', 'Responsivt design', 'Kontaktskjema', 'Grunnleggende SEO'],
    popular: false,
    pakkeValue: 'enkel',
  },
  {
    name: 'Standard',
    description: 'For bedrifter som vil ha litt mer',
    originalPrice: '15 000',
    launchPrice: '4 500',
    savings: '10 500',
    discountPercent: '70',
    monthly: '500',
    features: ['Inntil 10 sider', 'Alt i Enkel', 'Animasjoner', 'Google Analytics', 'Utvidet SEO'],
    popular: true,
    pakkeValue: 'standard',
  },
  {
    name: 'Premium',
    description: 'Skreddersydd design og funksjoner',
    originalPrice: '25 000',
    launchPrice: '10 000',
    savings: '15 000',
    discountPercent: '60',
    monthly: '750',
    features: ['Ubegrenset sider', 'Alt i Standard', 'Skreddersydd design', 'Avanserte funksjoner'],
    popular: false,
    pakkeValue: 'premium',
  },
];
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-4">
    <!-- Section header -->
    <div class="reveal-on-scroll mb-12 text-center">
      <h2 class="text-3xl font-bold md:text-4xl">Velg pakken som passer deg</h2>
      <p class="mt-4 text-text-muted">
        Alle pakker inkluderer SSL, hosting og support. Ingen skjulte kostnader.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {pakker.map((pakke, index) => (
        <div
          class={`reveal-on-scroll reveal-delay-${index + 1} relative flex flex-col overflow-hidden rounded-2xl border bg-surface-raised ${pakke.popular ? 'border-brand ring-1 ring-brand' : 'border-white/10'}`}
        >
          {/* Launch offer badge */}
          <div class="absolute left-0 top-0 rounded-br-lg bg-brand px-3 py-1 text-sm font-medium text-surface">
            Lanseringstilbud
          </div>
          {pakke.popular && (
            <div class="absolute right-0 top-0 rounded-bl-lg bg-brand px-3 py-1 text-sm font-medium text-surface">
              Mest populær
            </div>
          )}
          <div class="flex flex-1 flex-col p-6 pt-10">
            <div>
              <h3 class="text-xl font-bold">{pakke.name}</h3>
              <p class="mt-1 text-sm text-text-muted">{pakke.description}</p>
            </div>
            <div class="mt-4 space-y-2">
              <div>
                <div class="text-xs text-text-muted uppercase tracking-wide mb-1">Engangskostnad</div>
                <PriceDisplay
                  originalPrice={pakke.originalPrice}
                  launchPrice={pakke.launchPrice}
                  savings={pakke.savings}
                  size="sm"
                />
              </div>
              <div class="pt-2 border-t border-white/5">
                <div class="text-xs text-text-muted uppercase tracking-wide">Per måned</div>
                <div class="text-lg font-semibold">
                  {pakke.monthly} kr<span class="text-sm text-text-muted/70">/mnd</span>
                </div>
              </div>
            </div>
            <ul class="mt-4 flex-1 space-y-2">
              {pakke.features.map((feature) => (
                <li class="flex items-start gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-4 w-4 shrink-0 text-brand mt-0.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-sm text-text-muted">{feature}</span>
                </li>
              ))}
            </ul>
            <div class="mt-6">
              <button
                type="button"
                data-pakke={pakke.pakkeValue}
                class={`package-select-btn block w-full rounded-full px-6 py-3 text-center font-medium transition-all hover:scale-[1.02] active:scale-100 ${
                  pakke.popular
                    ? 'bg-brand text-surface hover:bg-brand-light hover:shadow-lg hover:shadow-brand/25'
                    : 'border border-white/20 text-text hover:border-brand hover:text-brand'
                }`}
              >
                Velg {pakke.name}
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Scarcity counter -->
    <div class="reveal-on-scroll mt-8 flex justify-center">
      <ScarcityCounter total={10} taken={0} variant="inline" />
    </div>

    <!-- Additional trust text -->
    <p class="reveal-on-scroll mt-6 text-center text-sm text-text-muted">
      Usikker? <a href="#kontakt" class="text-brand hover:text-brand-light">Ta en uforpliktende prat</a> – vi hjelper deg å velge riktig.
    </p>

    <!-- Guarantee banner -->
    <div class="reveal-on-scroll mx-auto mt-12 max-w-3xl rounded-2xl border border-brand/20 bg-gradient-to-br from-brand/5 to-brand/10 p-8 shadow-lg shadow-brand/5">
      <div class="flex flex-col items-start gap-6 md:flex-row md:items-center">
        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand/20 ring-4 ring-brand/10">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-8 w-8 text-brand"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
            />
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-xl font-bold md:text-2xl">Fornøyd-eller-pengene-tilbake-garanti</h3>
          <p class="mt-2 text-text-muted">
            Vi er så sikre på at du vil elske din nye nettside at vi tilbyr <strong class="text-text">full refusjon</strong> hvis du ikke er fornøyd innen 30 dager etter levering. Ingen spørsmål stilt.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Handle package selection clicks
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.package-select-btn');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const pakke = button.getAttribute('data-pakke');

        if (pakke) {
          // Update URL with query parameter
          const newUrl = `${window.location.pathname}?pakke=${pakke}#kontakt`;
          window.history.pushState({ pakke }, '', newUrl);

          // Trigger storage event to notify ContactForm
          window.dispatchEvent(new CustomEvent('pakkeSelected', { detail: { pakke } }));

          // Smooth scroll to form
          const kontaktSection = document.getElementById('kontakt');
          if (kontaktSection) {
            kontaktSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  });
</script>
