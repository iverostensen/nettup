---
/**
 * PricingSummary - Single subscription offer card
 *
 * Interim version showing the 0 kr / 399 kr/mnd subscription offer.
 * Phase 33 will rebuild this fully.
 */
import { subscriptionOffer } from '@/config/subscriptionOffer';
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-4">
    <!-- Section header -->
    <div class="reveal-on-scroll mb-12 text-center">
      <h2 class="text-3xl font-bold md:text-4xl">Alt du trenger for en profesjonell nettside</h2>
      <p class="mt-4 text-text-muted">
        SSL, hosting og support inkludert. Ingen skjulte kostnader.
      </p>
    </div>

    <!-- Single offer card -->
    <div class="reveal-on-scroll mx-auto max-w-md">
      <div class="relative flex flex-col overflow-hidden rounded-2xl border border-brand ring-1 ring-brand bg-surface-raised">
        <div class="flex flex-1 flex-col p-8">
          <!-- Price -->
          <div class="space-y-2 text-center">
            <div class="text-sm font-medium uppercase tracking-wide text-brand">Oppstart</div>
            <div class="text-4xl font-bold">0 kr</div>
            <div class="mt-4 border-t border-white/10 pt-4">
              <div class="text-sm font-medium uppercase tracking-wide text-brand">Per måned</div>
              <div class="text-4xl font-bold">
                399 kr<span class="text-lg text-text-muted">/mnd</span>
              </div>
            </div>
          </div>

          <!-- Features -->
          <ul class="mt-8 space-y-3">
            {subscriptionOffer.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="h-5 w-5 shrink-0 text-brand mt-0.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-text-muted">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- Terms -->
          <div class="mt-6 text-center text-sm text-text-muted">
            <span>{subscriptionOffer.terms.binding}</span>
          </div>

          <!-- CTA -->
          <div class="mt-8">
            <a
              href="#kontakt"
              class="block w-full rounded-full bg-brand px-6 py-3 text-center font-medium text-surface transition-all hover:bg-brand-light hover:scale-[1.02] hover:shadow-lg hover:shadow-brand/25 active:scale-100"
            >
              Kom i gang
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional trust text -->
    <p class="reveal-on-scroll mt-6 text-center text-sm text-text-muted">
      Usikker? <a href="#kontakt" class="text-brand hover:text-brand-light">Ta en uforpliktende prat</a> – vi hjelper deg med alt.
    </p>

    <!-- Guarantee banner -->
    <div class="reveal-on-scroll mx-auto mt-12 max-w-3xl rounded-2xl border border-brand/20 bg-gradient-to-br from-brand/5 to-brand/10 p-8 shadow-lg shadow-brand/5">
      <div class="flex flex-col items-start gap-6 md:flex-row md:items-center">
        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand/20 ring-4 ring-brand/10">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-8 w-8 text-brand"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
            />
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-xl font-bold md:text-2xl">Risikofri oppstart</h3>
          <p class="mt-2 text-text-muted">
            Ikke fornøyd etter første måned? Da betaler du ingenting. Med 0 kr i oppstart risikerer du kun 399 kr – og vi jobber til du er fornøyd.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
