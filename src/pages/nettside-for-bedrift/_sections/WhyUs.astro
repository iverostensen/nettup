---
/**
 * WhyUs - Why choose Nettup section
 *
 * Differentiators, values, and what sets us apart from competitors
 * Combines process overview with trust-building elements
 */

const reasons = [
  {
    icon: 'bolt',
    title: 'Raske leveranser',
    description: 'Nettsiden din er klar på 1-3 uker. Vi starter umiddelbart etter bestilling.',
    highlight: '1-3 uker',
  },
  {
    icon: 'code',
    title: 'Moderne teknologi',
    description: 'Vi bruker den nyeste teknologien for raske, sikre nettsider som ser profesjonelle ut på alle enheter.',
    highlight: 'Toppmoderne',
  },
  {
    icon: 'price',
    title: 'Ingen stor investering',
    description: '0 kr i oppstart betyr null risiko. Du betaler kun 399 kr/mnd for en komplett nettside med alt inkludert.',
    highlight: '0 kr oppstart',
  },
  {
    icon: 'shield',
    title: 'Alt inkludert',
    description: 'Hosting, SSL, support og vedlikehold er inkludert i månedsprisen. Du trenger ikke tenke på noe teknisk.',
    highlight: 'Ingen ekstra',
  },
  {
    icon: 'support',
    title: 'Norsk support',
    description: 'Vi snakker norsk og svarer innen 24 timer. Du får en dedikert kontaktperson som kjenner bedriften din.',
    highlight: '24t respons',
  },
  {
    icon: 'flexibility',
    title: 'Ingen bindingstid',
    description: 'Du kan si opp når som helst. Vi tror på at kvaliteten vår holder deg som kunde, ikke en kontrakt.',
    highlight: 'Fritt valg',
  },
];
---

<section class="py-16 md:py-24 bg-surface">
  <div class="container mx-auto px-4">
    <!-- Section header -->
    <div class="reveal-on-scroll mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold md:text-4xl">Hvorfor velge Nettup?</h2>
      <p class="mt-4 text-lg text-text-muted">
        Alt du trenger for en profesjonell nettside, uten stor investering.
      </p>
    </div>

    <!-- Reasons grid -->
    <div class="reveal-on-scroll delay-1 mx-auto mt-12 grid max-w-6xl gap-6 md:grid-cols-2 lg:grid-cols-3">
      {reasons.map((reason, index) => (
        <div class="reveal-on-scroll group rounded-2xl border border-white/10 bg-surface-raised p-6 transition-all hover:border-brand/30 hover:shadow-lg hover:shadow-brand/5" style={`animation-delay: ${(index + 1) * 100}ms`}>
          <!-- Icon -->
          <div class="flex items-center justify-between">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand/10 transition-all group-hover:bg-brand/20">
              {reason.icon === 'bolt' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-brand">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                </svg>
              )}
              {reason.icon === 'code' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-brand">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
                </svg>
              )}
              {reason.icon === 'shield' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-brand">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                </svg>
              )}
              {reason.icon === 'price' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-brand">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
                </svg>
              )}
              {reason.icon === 'support' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-brand">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 12 3.259c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                </svg>
              )}
              {reason.icon === 'flexibility' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6 text-brand">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
              )}
            </div>
            <span class="rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold text-brand">
              {reason.highlight}
            </span>
          </div>

          <!-- Content -->
          <h3 class="mt-4 text-lg font-semibold">{reason.title}</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            {reason.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Process overview -->
    <div class="reveal-on-scroll delay-2 mx-auto mt-16 max-w-4xl">
      <div class="rounded-2xl border border-white/10 bg-surface-raised p-8">
        <h3 class="text-center text-2xl font-bold">Sånn jobber vi</h3>
        <div class="mt-8 grid gap-6 md:grid-cols-3">
          <div class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-xl font-bold text-brand">
              1
            </div>
            <h4 class="mt-4 font-semibold">Kartlegging</h4>
            <p class="mt-2 text-sm text-text-muted">
              Vi starter med en samtale for å forstå dine behov og mål.
            </p>
          </div>
          <div class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-xl font-bold text-brand">
              2
            </div>
            <h4 class="mt-4 font-semibold">Design & utvikling</h4>
            <p class="mt-2 text-sm text-text-muted">
              Vi designer og bygger nettsiden med fokus på hastighet og kvalitet.
            </p>
          </div>
          <div class="text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-xl font-bold text-brand">
              3
            </div>
            <h4 class="mt-4 font-semibold">Lansering & support</h4>
            <p class="mt-2 text-sm text-text-muted">
              Vi lanserer nettsiden din og tar oss av hosting, oppdateringer og support så lenge du er kunde.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="reveal-on-scroll delay-3 mt-12 text-center">
      <p class="text-lg text-text-muted mb-4">
        Klar for å komme i gang?
      </p>
      <a
        href="#kontakt"
        class="inline-flex items-center gap-2 rounded-full bg-brand px-8 py-4 font-semibold text-surface transition-all hover:scale-105 hover:bg-brand-light hover:shadow-lg hover:shadow-brand/25 active:scale-100"
      >
        Kom i gang – 0 kr oppstart
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="h-5 w-5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
