---
/**
 * FormSection - Embedded contact form for landing page
 *
 * Wraps the ContactForm island with:
 * - Section heading with urgency
 * - Trust indicators alongside
 * - id="kontakt" for anchor scrolling
 */
import ContactForm from '@/pages/kontakt/_sections/ContactForm';
---

<section id="kontakt" class="scroll-mt-20 py-16 md:py-24">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-4xl">
      <!-- Section header -->
      <div class="reveal-on-scroll mb-10 text-center">
        <h2 class="text-3xl font-bold md:text-4xl">
          Få et uforpliktende tilbud
        </h2>
        <p class="mt-4 text-text-muted">
          Fyll ut skjemaet, så kontakter vi deg innen 24 timer.
        </p>
      </div>

      <div class="grid gap-10 lg:grid-cols-5 lg:gap-12">
        <!-- Trust indicators (side column on desktop) -->
        <div class="reveal-on-scroll reveal-delay-1 order-2 lg:order-1 lg:col-span-2">
          <div class="rounded-2xl border border-white/10 bg-surface-raised p-6">
            <h3 class="mb-6 font-semibold">Hvorfor velge Nettup?</h3>

            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand/10">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-4 w-4 text-brand"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
                    />
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Rask levering</p>
                  <p class="text-sm text-text-muted">Nettside klar på 1-3 uker</p>
                </div>
              </li>

              <li class="flex items-start gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand/10">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-4 w-4 text-brand"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
                    />
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Transparent pris</p>
                  <p class="text-sm text-text-muted">Ingen skjulte kostnader</p>
                </div>
              </li>

              <li class="flex items-start gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand/10">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-4 w-4 text-brand"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                    />
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Ingen binding</p>
                  <p class="text-sm text-text-muted">Du eier din nettside</p>
                </div>
              </li>

              <li class="flex items-start gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand/10">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-4 w-4 text-brand"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"
                    />
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Norsk support</p>
                  <p class="text-sm text-text-muted">Vi snakker ditt språk</p>
                </div>
              </li>
            </ul>

            <!-- Quick contact alternatives -->
            <div class="mt-6 border-t border-white/10 pt-6">
              <p class="text-sm text-text-muted mb-3">
                Foretrekker å snakke med oss direkte?
              </p>
              <div class="space-y-2">
                <a
                  href="tel:+4747331298"
                  class="flex items-center gap-2 text-brand hover:text-brand-light"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                    />
                  </svg>
                  +47 473 31 298
                </a>
                <a
                  href="mailto:post@nettup.no"
                  class="flex items-center gap-2 text-brand hover:text-brand-light"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                    />
                  </svg>
                  post@nettup.no
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div class="reveal-on-scroll order-1 lg:order-2 lg:col-span-3">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>
</section>
