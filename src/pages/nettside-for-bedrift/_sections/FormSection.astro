---
/**
 * FormSection - Embedded contact form for landing page
 *
 * Simplified single-column layout to reduce visual clutter
 * and focus attention on the form conversion action.
 * - id="kontakt" for anchor scrolling
 * - Dynamic heading based on selected package
 */
import ContactForm from '@/pages/kontakt/_sections/ContactForm';

// Package names for dynamic heading
const pakkeNames: Record<string, string> = {
  enkel: 'Enkel-pakken',
  standard: 'Standard-pakken',
  premium: 'Premium-pakken',
};
---

<section id="kontakt" class="scroll-mt-20 py-16 md:py-24 bg-surface">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl">
      <!-- Section header with dynamic title -->
      <div class="reveal-on-scroll mb-8 text-center">
        <h2 class="text-3xl font-bold md:text-4xl" id="form-heading">
          Få et uforpliktende tilbud
        </h2>
        <p class="mt-4 text-text-muted">
          Fyll ut skjemaet, så kontakter vi deg innen 24 timer.
        </p>
        <!-- Simplified trust line -->
        <div class="mt-4 flex items-center justify-center gap-4 text-sm text-text-muted/70">
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4 text-brand">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            24t respons
          </span>
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4 text-brand">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            Ingen binding
          </span>
        </div>
      </div>

      <!-- Contact form (centered, single focus) -->
      <div class="reveal-on-scroll delay-1">
        <ContactForm client:load context="b2b" />
      </div>

      <!-- Alternative contact options (subtle, below form) -->
      <div class="reveal-on-scroll delay-2 mt-8 border-t border-white/5 pt-8 text-center">
        <p class="text-sm text-text-muted mb-3">
          Foretrekker å ringe eller sende e-post?
        </p>
        <div class="flex items-center justify-center gap-6 text-sm">
          <a
            href="tel:+4741327136"
            class="flex items-center gap-2 text-brand hover:text-brand-light transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
              />
            </svg>
            +47 413 27 136
          </a>
          <a
            href="mailto:post@nettup.no"
            class="flex items-center gap-2 text-brand hover:text-brand-light transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              />
            </svg>
            post@nettup.no
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ pakkeNames }} is:inline>
  // Update heading based on URL parameter
  if (typeof window !== 'undefined') {
    const params = new URLSearchParams(window.location.search);
    const pakke = params.get('pakke');

    if (pakke && pakkeNames[pakke]) {
      const heading = document.getElementById('form-heading');
      if (heading) {
        heading.textContent = `Få tilbud på ${pakkeNames[pakke]}`;
      }
    }
  }
</script>
