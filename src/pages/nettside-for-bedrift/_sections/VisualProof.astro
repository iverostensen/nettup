---
/**
 * VisualProof - Website preview screenshot
 *
 * Shows actual iGive project as example of what we deliver.
 * Focuses on visual quality, not technical metrics.
 */
import { Image } from 'astro:assets';
import iGiveImage from '@/assets/images/igive-hero.png';
---

<section class="py-16 md:py-24 bg-surface">
  <div class="container mx-auto px-4">
    <!-- Section header -->
    <div class="reveal-on-scroll mb-12 text-center max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold md:text-4xl">Slik kan din nettside se ut</h2>
      <p class="mt-4 text-text-muted">
        Vi bygger moderne, raske nettsider som fungerer på alle enheter. Her er et eksempel fra en av våre kunder.
      </p>
    </div>

    <!-- Visual proof with screenshot -->
    <div class="reveal-on-scroll delay-1 mx-auto max-w-5xl">
      <div class="relative rounded-2xl border border-white/10 bg-surface-raised p-4 md:p-8 overflow-hidden">
        <!-- Screenshot -->
        <div class="relative rounded-lg overflow-hidden border border-white/10">
          <Image
            src={iGiveImage}
            alt="iGive salgsside - profesjonell nettside laget av Nettup"
            width={1200}
            quality={85}
            class="w-full h-auto"
            loading="lazy"
          />

          <!-- Logo badge overlay on screenshot -->
          <div class="absolute top-4 left-4 rounded-lg bg-white/95 backdrop-blur-sm border border-white/20 px-3 py-2 shadow-lg">
            <div class="flex items-center gap-3">
              <img
                src="/images/igive-logo.svg"
                alt="iGive"
                class="h-6 w-auto"
              />
              <div class="h-4 w-px bg-gray-300"></div>
              <div class="text-xs text-gray-600 font-medium">Kunde</div>
            </div>
          </div>
        </div>

        <!-- Attribution -->
        <div class="mt-6 text-center">
          <p class="text-sm text-text-muted">
            Levert for iGive i januar 2026.{' '}
            <a href="/prosjekter" class="text-brand hover:text-brand-light">
              Les hele case-studien →
            </a>
          </p>
        </div>
      </div>
    </div>

    <!-- Trust reinforcement -->
    <div class="reveal-on-scroll delay-2 mt-12 text-center">
      <p class="text-text-muted">
        Alle nettsider inkluderer responsivt design, SEO og SSL-sertifikat
      </p>
    </div>
  </div>
</section>
