---
/**
 * LogoCloud - Featured client showcase
 *
 * Shows iGive as a featured success story
 * Can be expanded as more clients are added
 */
---

<section class="py-12 md:py-16 border-y border-white/5">
  <div class="container mx-auto px-4">
    <div class="reveal-on-scroll mx-auto max-w-2xl text-center">
      <!-- Section header -->
      <p class="text-sm text-text-muted uppercase tracking-wide mb-6">
        Siste prosjekt
      </p>

      <!-- Featured client -->
      <div class="inline-flex items-center justify-center p-8 rounded-xl bg-white">
        <img
          src="/images/igive-logo.svg"
          alt="iGive - Nettup kunde"
          class="h-16 w-auto"
        />
      </div>

      <!-- Description -->
      <p class="mt-6 text-text-muted">
        Norges ledende gavekortplattform med over 16 000 brukersteder og 352 millioner kroner i omløp
      </p>

      <!-- CTA -->
      <p class="mt-4 text-sm text-text-muted">
        <a href="#kontakt" class="text-brand hover:text-brand-light">
          Få samme resultater for din bedrift →
        </a>
      </p>
    </div>
  </div>
</section>
