---
/**
 * Landing Page: /nettside-for-bedrift/
 *
 * Dedicated Google Ads landing page for keyword "nettside for bedrift"
 *
 * Key optimizations:
 * - Headline matches ad keyword exactly
 * - No navigation (reduces exits)
 * - Form embedded on page (no click to /kontakt/)
 * - Trust signals throughout
 * - Phone CTA in header
 * - Results section for social proof (Lighthouse scores)
 * - Testimonial from real customer (iGive)
 * - FAQ section with JSON-LD schema for rich snippets
 */
import LandingPageLayout from '@/layouts/LandingPageLayout.astro';
import Hero from './_sections/Hero.astro';
import VisualProof from './_sections/VisualProof.astro';
import LogoCloud from './_sections/LogoCloud.astro';
import Testimonial from './_sections/Testimonial.astro';
import WhyUs from './_sections/WhyUs.astro';
import PricingSummary from './_sections/PricingSummary.astro';
import FAQ from './_sections/FAQ.astro';
import FormSection from './_sections/FormSection.astro';
---

<LandingPageLayout
  title="Nettside for Bedrift | Fra 7 000 kr | Nettup"
  description="Profesjonell nettside for din bedrift. Moderne, rask og SEO-optimalisert. Fra 7 000 kr, klar på 1-3 uker. Gratis tilbud!"
>
  <main>
    <Hero />
    <VisualProof />
    <LogoCloud />
    <Testimonial />
    <WhyUs />
    <PricingSummary />
    <FAQ />
    <FormSection />
  </main>
</LandingPageLayout>
