---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Page-specific sections
import Hero from './_home/Hero.astro';
import Problem from './_home/Problem.astro';
import Solution from './_home/Solution.astro';
import WhyNettup from './_home/WhyNettup.astro';
import Process from './_home/Process.astro';
import ProjectTeaser from './_home/ProjectTeaser.astro';

// Shared sections
import CTA from '@/components/sections/CTA.astro';
---

<BaseLayout
  title="Nettside for Bedrift | Fra 2 500 kr (Lanseringstilbud) | Nettup"
  description="Moderne, raske nettsider for norske bedrifter. Lanseringstilbud: Fra 2 500 kr (ordinært 7 000 kr). Klar på 1-3 uker."
>
  <main>
    <Hero />
    <Problem />
    <Solution />
    <WhyNettup />
    <Process />
    <ProjectTeaser />
    <CTA />
  </main>
</BaseLayout>
