---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Page-specific sections
import Hero from './_home/Hero.astro';
import Problem from './_home/Problem.astro';
import Solution from './_home/Solution.astro';
import WhyNettup from './_home/WhyNettup.astro';
import Process from './_home/Process.astro';
import ProjectTeaser from './_home/ProjectTeaser.astro';
import Testimonials from './_home/Testimonials.astro';

// Shared sections
import CTA from '@/components/sections/CTA.astro';
---

<BaseLayout
  title="Nettup | Webbyrå for norske bedrifter"
  description="Vi lager moderne, raske nettsider for norske bedrifter. Uten stress, til rett pris. Se våre referanser og ta kontakt."
>
  <main>
    <Hero />
    <Problem />
    <Solution />
    <WhyNettup />
    <Process />
    <ProjectTeaser />
    <Testimonials />
    <CTA />
  </main>
</BaseLayout>
