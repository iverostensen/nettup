---
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import Button from '@/components/ui/Button.astro';
---

<section class="bg-surface py-24 pt-32 md:py-32 md:pt-40">
  <div class="container mx-auto max-w-4xl px-4">
    <Breadcrumbs items={[
      { label: 'Hjem', href: '/' },
      { label: 'Tjenester', href: '/tjenester' },
      { label: 'AI-løsning' },
    ]} />
    <h1 class="animate-fade-up mt-6 font-display text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
      Automatiser det som stjeler tid — skreddersydde AI-løsninger for din bedrift
    </h1>
    <p class="animate-fade-up mt-6 text-lg text-text-muted md:text-xl" style="animation-delay: 100ms">
      Vi bygger AI-løsninger som gjør reelt arbeid: svarer på kundehenvendelser, behandler dokumenter og kobler systemene dine sammen — uten manuelle mellomledd. Ingen generiske verktøy med kunstige begrensninger. En løsning bygget rundt din arbeidsflyt.
    </p>
    <p class="animate-fade-up mt-4 text-xl font-semibold text-brand" style="animation-delay: 150ms">
      fra 20 000 kr
    </p>
    <p class="animate-fade-up mt-2 text-base text-text-muted" style="animation-delay: 175ms">
      + fra 1 000 kr/mnd vedlikehold
    </p>
    <div class="animate-fade-up mt-8" style="animation-delay: 200ms">
      <Button href="/kontakt?tjeneste=ai" size="lg">Få et gratis tilbud</Button>
    </div>
  </div>
</section>
