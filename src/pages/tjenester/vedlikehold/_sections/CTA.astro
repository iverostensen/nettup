---
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
---

<Section background="raised">
  <div class="reveal-on-scroll mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold md:text-4xl">
      La oss ta ansvar for det tekniske
    </h2>
    <p class="mt-4 text-lg text-text-muted">
      Start med en gratis gjennomgang av nettstedet ditt. Vi ser på hva som kan forbedres og forteller deg hva en vedlikeholdsavtale vil koste — uten forpliktelser.
    </p>
    <div class="mt-8">
      <Button href="/kontakt?tjeneste=vedlikehold" size="lg">Start med en gratis gjennomgang</Button>
    </div>
  </div>
</Section>
