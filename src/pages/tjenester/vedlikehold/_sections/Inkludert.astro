---
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const features = [
  { title: 'Oppdateringer av rammeverk og pakker', description: 'Vi holder alle tekniske komponenter oppdatert. Utdaterte pakker er en av de vanligste sikkerhetssårbarhetene — det håndterer vi for deg.' },
  { title: 'Sikkerhetsovervåking og patching', description: 'Vi overvåker nettsiden for kjente sårbarheter og patcher dem fortløpende. Sikkerhetsbrudd er kostbart — vi sørger for at du er i forkant.' },
  { title: 'Månedlig sikkerhetssjekk', description: 'Hver måned gjennomgår vi nettsiden for problemer du kanskje ikke ser selv — brutte lenker, treige sider og tekniske feil.' },
  { title: 'Teknisk support', description: 'Noe galt? Send oss en e-post. Vi svarer innen 24 timer på hverdager og løser det som trengs.' },
  { title: 'Ytelsesovervåking', description: 'Vi følger med på lastehastighet og tilgjengelighet. Trege nettsider mister besøkende — vi sørger for at din presterer.' },
  { title: 'Domene- og sertifikathåndtering', description: 'Vi passer på at domenet og SSL-sertifikatet ditt fornyes i tide. Du slipper å huske på fornyelsesdatoer og risikere nedetid.' },
  { title: 'Backup-rutiner', description: 'Vi tar jevnlige sikkerhetskopier av nettsiden din. Skjer det noe uforutsett, kan vi gjenopprette raskt uten at du mister innhold.' },
];
---

<Section background="raised">
  <SectionHeader
    title="Hva din månedlige avtale dekker"
    subtitle="Alle Nettup-kunder får dette — ingen skjulte tillegg."
  />
  <div class="mx-auto max-w-4xl">
    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {features.map((feature, index) => (
        <div class={`reveal-on-scroll delay-${(index % 3) + 1}`}>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-5 w-5 shrink-0 text-brand" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <div>
              <h3 class="font-semibold">{feature.title}</h3>
              <p class="mt-1 text-sm text-text-muted">{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
