---
import Button from '@/components/ui/Button.astro';
---

<section class="flex min-h-[60vh] items-center justify-center px-4 pt-20">
  <div class="text-center">
    <h1 class="animate-fade-up text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
      Tjenester og priser
    </h1>
    <p
      class="animate-fade-up mx-auto mt-6 max-w-2xl text-lg text-text-muted md:text-xl"
      style="animation-delay: 100ms"
    >
      Tydelige pakker, faste priser. Ingen overraskelser.
    </p>
  </div>
</section>
