---
import { services } from '@/config/services';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import TjenesterOversiktIsland from '@/components/islands/TjenesterOversiktIsland';

const featured = services.filter((s) => s.featured).map((s) => s.slug);
---

<Section class="pt-32 md:pt-40">
  <SectionHeader title="Hva trenger du?" subtitle="Vi bygger tre typer nettsteder — alle skreddersydd, alle eiet av deg. Velg det som passer din situasjon." />

  <p class="reveal-on-scroll -mt-4 mb-10 text-sm text-text-muted">
    Usikker på hva som passer? <a href="/kontakt" class="text-brand underline-offset-2 hover:underline">Ta en uforpliktende prat</a> — vi hjelper deg å velge riktig.
  </p>

  <TjenesterOversiktIsland
    client:visible
    services={services}
    featured={featured}
  />
</Section>
