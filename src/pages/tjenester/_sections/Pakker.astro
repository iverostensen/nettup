---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import ScarcityCounter from '@/components/ui/ScarcityCounter.astro';
import PriceDisplay from '@/components/ui/PriceDisplay.astro';
import { launchOffer } from '@/config/launchOffer';

const pakker = [
  {
    name: 'Enkel',
    description: 'For deg som trenger en enkel, profesjonell tilstedeværelse på nett.',
    originalPrice: '7 000',
    launchPrice: '2 500',
    savings: '4 500',
    discountPercent: '64',
    monthly: '350',
    support: '30 min utvikling/mnd',
    features: [
      'Inntil 5 sider',
      'Responsivt design',
      'Kontaktskjema',
      'Grunnleggende SEO',
    ],
    popular: false,
  },
  {
    name: 'Standard',
    description: 'For bedrifter som vil ha litt mer - animasjoner, flere sider, og SEO-fokus.',
    originalPrice: '15 000',
    launchPrice: '4 500',
    savings: '10 500',
    discountPercent: '70',
    monthly: '500',
    support: '1 time utvikling/mnd',
    features: [
      'Inntil 10 sider',
      'Alt i Enkel-pakken',
      'Animasjoner og overganger',
      'Google Analytics-oppsett',
      'Utvidet SEO-optimalisering',
    ],
    popular: true,
  },
  {
    name: 'Premium',
    description: 'For de som vil skille seg ut med skreddersydd design og avanserte funksjoner.',
    originalPrice: '25 000',
    launchPrice: '10 000',
    savings: '15 000',
    discountPercent: '60',
    monthly: '750',
    support: '2 timer utvikling/mnd',
    features: [
      'Ubegrenset antall sider',
      'Alt i Standard-pakken',
      'Skreddersydd design',
      'Avanserte funksjoner',
      'Prioritert support',
    ],
    popular: false,
  },
];
---

<section class="pt-28 pb-16 md:pt-36 md:pb-24">
  <div class="container">
    <SectionHeader
      title="Velg pakken som passer deg"
      subtitle="Alle pakker inkluderer SSL-sertifikat, hosting og løpende support."
    />
    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {pakker.map((pakke, index) => (
        <div
          class={`reveal-on-scroll reveal-delay-${index + 1} relative flex flex-col overflow-hidden rounded-2xl border bg-surface-raised ${pakke.popular ? 'border-brand ring-1 ring-brand' : 'border-white/10'}`}
        >
          {/* Launch offer badge */}
          <div class="absolute left-0 top-0 rounded-br-lg bg-brand px-3 py-1 text-sm font-medium text-surface">
            Lanseringstilbud
          </div>
          {pakke.popular && (
            <div class="absolute right-0 top-0 rounded-bl-lg bg-brand px-3 py-1 text-sm font-medium text-surface">
              Mest populær
            </div>
          )}
          <div class="flex flex-1 flex-col p-6 pt-10 md:p-8 md:pt-12">
            <div>
              <h3 class="text-2xl font-bold">{pakke.name}</h3>
              <p class="mt-2 text-sm text-text-muted">{pakke.description}</p>
            </div>
            <div class="mt-6">
              <PriceDisplay
                originalPrice={pakke.originalPrice}
                launchPrice={pakke.launchPrice}
                savings={pakke.savings}
                monthly={pakke.monthly}
                size="md"
              />
              <p class="mt-1 text-xs text-text-muted/70">({pakke.support})</p>
            </div>
            <ul class="mt-6 flex-1 space-y-3">
              {pakke.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-5 w-5 shrink-0 text-brand"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-sm text-text-muted">{feature}</span>
                </li>
              ))}
            </ul>
            <div class="mt-8">
              <Button
                href="/kontakt"
                variant={pakke.popular ? 'primary' : 'secondary'}
                class="w-full"
              >
                Kom i gang
              </Button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Scarcity counter -->
    <div class="reveal-on-scroll mt-8 flex justify-center">
      <ScarcityCounter total={launchOffer.total} taken={launchOffer.taken} variant="inline" />
    </div>
  </div>
</section>
