---
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
---

<Section background="raised">
  <div class="reveal-on-scroll mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold md:text-4xl">
      Klar til å åpne nettbutikken din?
    </h2>
    <p class="mt-4 text-lg text-text-muted">
      Ta kontakt for en uforpliktende prat om produktene dine og hva slags butikk du trenger. Vi svarer innen 24 timer.
    </p>
    <div class="mt-8">
      <Button href="/kontakt?tjeneste=nettbutikk" size="lg">Få et gratis tilbud</Button>
    </div>
  </div>
</Section>
