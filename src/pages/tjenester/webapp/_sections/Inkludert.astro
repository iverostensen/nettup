---
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const features = [
  { title: 'Behovsanalyse og prototyp', description: 'Vi kartlegger kravene grundig og leverer et klikkbart utkast du kan godkjenne før utviklingen starter.' },
  { title: 'Skreddersydd løsning', description: 'Ingen malbaserte løsninger med kunstige begrensninger. Applikasjonen bygges rundt prosessene dine, ikke omvendt.' },
  { title: 'Integrasjoner med eksisterende systemer', description: 'Vi kobler webappen til verktøyene bedriften allerede bruker — regnskapssystem, CRM, API-er eller databaser.' },
  { title: 'Brukertesting før lansering', description: 'Reelle brukere tester løsningen før den settes i produksjon. Feil og forbedringsmuligheter avdekkes før de koster deg tid.' },
  { title: 'Responsivt design', description: 'Løsningen fungerer på mobil, tablet og desktop. Teamet ditt kan bruke den uansett enhet.' },
  { title: 'Sikker innlogging', description: 'Vi kan implementere rollebasert tilgangskontroll slik at riktige personer ser riktig innhold — ingen mer enn de trenger.' },
  { title: 'Hosting og driftsoppsett', description: 'Vi setter opp og konfigurerer infrastrukturen. Du slipper å forholde deg til servere og driftsmiljøer.' },
  { title: '30 dagers support etter lansering', description: 'Vi er tilgjengelige for spørsmål, justeringer og feilretting i 30 dager etter at løsningen er i produksjon — uten ekstra kostnad.' },
];
---

<Section background="raised">
  <SectionHeader
    title="Hva er inkludert"
    subtitle="Fra krav til ferdig løsning — uten skjulte kostnader."
  />
  <div class="mx-auto max-w-4xl">
    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {features.map((feature, index) => (
        <div class={`reveal-on-scroll delay-${(index % 3) + 1}`}>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-5 w-5 shrink-0 text-brand" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <div>
              <h3 class="font-semibold">{feature.title}</h3>
              <p class="mt-1 text-sm text-text-muted">{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
