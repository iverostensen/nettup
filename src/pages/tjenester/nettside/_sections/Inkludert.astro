---
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const features = [
  { title: 'Responsivt design', description: 'Nettsiden ser bra ut og fungerer perfekt på mobil, tablet og desktop — uten ekstra arbeid fra din side.' },
  { title: 'Skreddersydd design', description: 'Ingen maler. Vi designer en nettside som reflekterer merkevaren din og skiller seg ut fra konkurrentene.' },
  { title: 'Kontaktskjema', description: 'Gjør det enkelt for potensielle kunder å ta kontakt. Skjemaet sendes direkte til din e-post.' },
  { title: 'Grunnleggende SEO', description: 'Riktige metatagsjer, rask lasting og god struktur slik at Google finner og indekserer nettsiden din.' },
  { title: 'HTTPS/SSL', description: 'Sikker kryptert tilkobling inkludert. Nødvendig for tillit og Google-rangering.' },
  { title: 'Hosting', description: 'Rask og pålitelig hosting inkludert i prosjektprisen. Du slipper å sette opp noe selv.' },
  { title: 'CMS (valgfritt)', description: 'Ønsker du å oppdatere innhold selv? Vi setter opp et enkelt CMS så du ikke er avhengig av oss for tekstendringer.' },
  { title: '30 dagers support', description: 'Etter lansering er vi tilgjengelige for spørsmål, justeringer og feilretting i 30 dager — uten ekstra kostnad.' },
];
---

<Section background="raised">
  <SectionHeader title="Hva er inkludert" subtitle="Alt du trenger fra dag én — ingen skjulte kostnader." />
  <div class="mx-auto max-w-4xl">
    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {features.map((feature, index) => (
        <div class={`reveal-on-scroll delay-${(index % 3) + 1}`}>
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-5 w-5 shrink-0 text-brand" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <div>
              <h3 class="font-semibold">{feature.title}</h3>
              <p class="mt-1 text-sm text-text-muted">{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
