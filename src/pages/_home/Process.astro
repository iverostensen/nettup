---
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const steps = [
  {
    number: '1',
    title: 'Samtale',
    description: 'Vi tar en kort prat om hva du trenger. Uforpliktende.',
  },
  {
    number: '2',
    title: 'Forslag',
    description: 'Du får et konkret forslag med pris. Ingen overraskelser.',
  },
  {
    number: '3',
    title: 'Bygging',
    description: 'Vi bygger nettsiden. Du ser fremgang underveis.',
  },
  {
    number: '4',
    title: 'Lansering',
    description: 'Nettsiden går live. Vi sørger for at alt fungerer.',
  },
];
---

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Slik jobber vi – fra samtale til lansering",
  "description": "Nettups 4-stegs prosess for å levere nettside til norske bedrifter.",
  "step": steps.map((s, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": s.title,
    "text": s.description,
  })),
})} />

<Section background="raised">
  <SectionHeader title="Slik jobber vi" />
  <div class="mx-auto max-w-4xl">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, index) => (
        <div class={`group reveal-on-scroll delay-${index + 1} relative`}>
          <div class="flex flex-col items-center text-center md:items-start md:text-left">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-brand text-lg font-bold text-surface transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-brand/30">
              {step.number}
            </div>
            <h3 class="text-lg font-semibold transition-colors duration-300 group-hover:text-brand">{step.title}</h3>
            <p class="mt-2 text-sm text-text-muted">{step.description}</p>
          </div>
          {index < steps.length - 1 && (
            <div class="absolute right-0 top-6 hidden h-px w-8 bg-gradient-to-r from-brand/30 to-transparent lg:block" style="transform: translateX(100%)"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</Section>
