---
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Card from '@/components/ui/Card.astro';

const features = [
  {
    title: 'Rask',
    description: 'Nettsidene våre laster på under 2 sekunder. Besøkende blir, Google liker det.',
    icon: 'bolt',
  },
  {
    title: 'Moderne',
    description: 'Design som ser profesjonelt ut i dag - og om to år.',
    icon: 'sparkles',
  },
  {
    title: 'Enkelt',
    description: 'Ingen sjargong, ingen uendelige møter. Du vet hva du får og hva det koster.',
    icon: 'check',
  },
];

const icons = {
  bolt: 'm3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z',
  sparkles: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z',
  check: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
};
---

<Section>
  <SectionHeader title="Hvorfor Nettup?" />
  <div class="grid gap-8 md:grid-cols-3">
    {features.map((feature, index) => (
      <Card
        as="article"
        padding="lg"
        hover
        class={`group reveal-on-scroll reveal-delay-${index + 1}`}
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand/10 transition-all duration-300 group-hover:bg-brand/20 group-hover:scale-110">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="h-6 w-6 text-brand transition-transform duration-300 group-hover:scale-110"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={icons[feature.icon as keyof typeof icons]} />
          </svg>
        </div>
        <h3 class="text-xl font-semibold">{feature.title}</h3>
        <p class="mt-2 text-text-muted">{feature.description}</p>
      </Card>
    ))}
  </div>
</Section>
