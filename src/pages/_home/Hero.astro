---
import Button from '@/components/ui/Button.astro';
import GradientBackground from '@/components/islands/GradientBackground';
import RotatingText from '@/components/islands/RotatingText';
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 pt-20">
  <!-- Animated gradient background -->
  <GradientBackground client:load />

  <div class="relative z-10 text-center">
    <h1 class="animate-fade-up text-4xl font-bold leading-tight md:text-6xl lg:text-7xl">
      Nettsider som<br />
      <RotatingText client:load />
    </h1>
    <p
      class="animate-fade-up mx-auto mt-6 max-w-2xl text-lg text-text-muted md:text-xl"
      style="animation-delay: 100ms"
    >
      Vi lager moderne, raske nettsider for norske bedrifter. Uten stress, til rett pris.
    </p>
    <div
      class="animate-fade-up mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
      style="animation-delay: 200ms"
    >
      <Button href="/kontakt" size="lg">Ta kontakt</Button>
      <Button href="/prosjekter" variant="secondary" size="lg">Se vårt arbeid</Button>
    </div>
  </div>
</section>
