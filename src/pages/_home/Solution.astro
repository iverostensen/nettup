---
import Section from '@/components/ui/Section.astro';
import LinkWithArrow from '@/components/ui/LinkWithArrow.astro';
---

<Section background="raised">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="reveal-on-scroll text-3xl font-bold md:text-4xl">
      Det finnes en enklere vei
    </h2>
    <p class="reveal-on-scroll delay-1 mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
      Vi bygger skreddersydde nettsider fra grunnen av — ingen maler, ingen WordPress. Du får noe som faktisk er laget for deg, levert på 2–4 uker og garantert scorer 95+ på Google. Til en pris som gir mening.
    </p>
    <div class="reveal-on-scroll delay-2 mt-10">
      <LinkWithArrow href="/tjenester">Se våre pakker og priser</LinkWithArrow>
    </div>
  </div>
</Section>
